{
  "name": "@ai-registry/retrieval-agent",
  "version": "0.1.0",
  "description": "A configurable retrieval agent for Vercel AI SDK v6 with web search capabilities",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
