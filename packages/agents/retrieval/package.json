  },
  "devDependencies": {
    "@ai-registry/eslint-config": "workspace:*",
    "@ai-registry/typescript-config": "workspace:*",
    "@ai-sdk/openai": "^3.0.5",
    "ai": "^6.0.12",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/ai-registry.git",
