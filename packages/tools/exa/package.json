{
  "name": "@ai-registry/exa",
  "version": "0.1.0",
  "description": "Exa tools with SDK-agnostic core and adapters for AI SDKs",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./ai-sdk": {
      "types": "./dist/adapters/ai-sdk.d.ts",
      "import": "./dist/adapters/ai-sdk.js"
    },
    "./tanstack-ai": {
      "types": "./dist/adapters/tanstack-ai.d.ts",
      "import": "./dist/adapters/tanstack-ai.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "example": "tsx",
    "example:basic": "tsx examples/basic-search.ts",
    "example:research": "tsx examples/research-papers.ts",
    "example:news": "tsx examples/news-search.ts",
    "example:contents": "tsx examples/fetch-contents.ts",
    "example:combined": "tsx examples/combined-workflow.ts",
    "example:core": "tsx examples/core-usage.ts"
  },
  "keywords": [
    "ai",
    "vercel-ai-sdk",
    "exa",
    "web-search",
    "web-contents",
    "tool",
    "agent",
    "llm",
    "sdk-agnostic"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@effect/platform": "^0.94.1",
    "@tanstack/ai": "^0.2.2",
    "@tanstack/ai-openai": "^0.2.1",
    "effect": "^3.20.0",
    "zod": "^4.3.5"
  },
  "peerDependencies": {
    "ai": "^4.0.0 || ^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-registry/eslint-config": "workspace:*",
    "@ai-registry/typescript-config": "workspace:*",
    "@ai-sdk/openai": "^3.0.12",
    "@types/node": "^22.15.0",
    "ai": "^6.0.39",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.2",
    "vitest": "^4.0.16"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/endalk200/ai-registry.git",
    "directory": "packages/tools/exa"
  }
}
